{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": ".tsbuild/test",
		"rootDir": "src",
		"tsBuildInfoFile": ".tsbuild/test/.tsbuildinfo",
		"types": ["node", "vitest/globals"]
	},
	"include": ["src/**/*.test.ts"],
	"references": [
		{ "path": "./tsconfig.build.json" }
	]
}
